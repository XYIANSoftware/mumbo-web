{
	"useTabs": true,
	"singleQuote": true,
	"jsxSingleQuote": true,
	"semi": false,
	"printWidth": 80,
	"tabWidth": 2,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "avoid",
	"endOfLine": "lf",
	"importOrder": [
		"^react",
		"^next",
		"^@/components/(.*)$",
		"^@/lib/(.*)$",
		"^@/hooks/(.*)$",
		"^@/types/(.*)$",
		"^@/styles/(.*)$",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true
}
